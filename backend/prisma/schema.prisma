// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgres"
}

enum SubscriptionTier {
  free
  starter
  pro
}

enum AuthProvider {
  local
  google
  discord
}

enum NotificationChannels {
  telegram
  discord
  slack
  email
}

model User {
  id            Int      @id @default(autoincrement())
  emailVerified Boolean  @default(false)
  username      String   @unique
  firstName     String?
  lastName      String?
  email         String   @unique
  password      String
  city          String?
  timezone      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authAccounts  AuthAccount[]
  events        Event[]
  orders        Orders[]
  billing       Billing?
  project       Project[]
  configuration Configuration?
}

model Configuration {
  id                   Int                    @id @default(autoincrement())
  eventsUsed           Int
  globalThrottleWindow Int
  eventTriggerCount    Int
  eventTriggerWindow   Int
  maxRetries           Int
  retryOffset          Int
  notificationChannels NotificationChannels[] @default([])
  userId               Int                    @unique

  user User @relation(fields: [userId], references: [id])
}

model Project {
  id             Int             @id @default(autoincrement())
  identifierKey  String          @unique
  identifierKey2 String          @unique
  projectName    String
  projectDesc    String
  userId         Int
  contactDetails ContactDetails?

  user User @relation(fields: [userId], references: [id])

  @@unique([projectName, userId])
}

enum CurrentStatus {
  active
  inactive
}

model Billing {
  id                Int              @id @default(autoincrement())
  subscription_tier SubscriptionTier
  currentStatus     CurrentStatus
  validTill         DateTime
  userId            Int              @unique
  user              User             @relation(fields: [userId], references: [id])
}

model AuthAccount {
  id         Int          @id @default(autoincrement())
  provider   AuthProvider
  providerId String       @unique
  userId     Int
  user       User         @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
  @@index([userId])
}

enum IssuePriority {
  unseen
  critical
  high
  low
  closed
}

enum Environment {
  production
  staging
  development
  qa
  uat
  sandbox
}

enum EventType {
  issue
  incident
}

model Event {
  id          Int            @id @default(autoincrement())
  type        EventType
  projectName String
  name        String
  description String
  priority    IssuePriority?

  throttlingWindow Int
  environment      Environment @default(production)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime? //For issue
  seenAt     DateTime? // For incident

  filePath                                String?
  occurrences                             Int       @default(1)
  occurrencesFromLastNotificationSent     Int
  firstOccurenceAfterLastNotificationSent DateTime?
  lineNumber                              Int?
  columnNumber                            Int?
  lastNotificationSent                    DateTime

  eventHashKey String

  group String?

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, type])
  @@index([userId, priority])
  @@index([userId, group])
}

model ContactDetails {
  id               Int      @id @default(autoincrement())
  telegramChatIds  String[] @default([])
  telegramChatIds2 String[] @default([]) // For "pro" tier
  discordChatIds   String[] @default([])
  discordChatIds2  String[] @default([]) // For "pro" tier
  emailIds         String[] @default([])
  emailIds2        String[] @default([]) // For "pro" tier
  projectId        Int      @unique

  project Project @relation(fields: [projectId], references: [id])
}

enum OrderStatus {
  pending
  successful
  failed
}

model Orders {
  id                Int         @id @default(autoincrement())
  razorPayOrderId   String      @unique
  razorPayPaymentId String?
  amount            Int
  status            OrderStatus
  note              String?
  userId            Int
  user              User        @relation(fields: [userId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @default(now()) @updatedAt

  @@index([userId])
}