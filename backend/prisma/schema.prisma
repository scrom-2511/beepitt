// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgres"
}

enum SubscriptionTier {
  Free
  Starter
  Pro
}

enum AuthProvider {
  LOCAL
  GOOGLE
  DISCORD
}

enum NotificationChannels {
  Telegram
  Discord
  Slack
  Email
}

model User {
  id                   Int                    @id @default(autoincrement())
  emailVerified        Boolean                @default(false)
  username             String                 @unique
  firstName            String?
  lastName             String?
  email                String                 @unique
  password             String
  city                 String?
  timezone             String?
  eventsUsed           Int
  notificationChannels NotificationChannels[] @default([])
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  authAccounts AuthAccount[]
  issues       Issue[]
  orders       Orders[]
  incidents    Incident[]
  billing      Billing?
  project      Project[]
}

model Project {
  id             Int             @id @default(autoincrement())
  identifierKey  String          @unique
  projectName    String
  userId         Int
  contactDetails ContactDetails?

  user User @relation(fields: [userId], references: [id])
}

enum CurrentStatus {
  Active
  Inactive
}

model Billing {
  id                Int              @id @default(autoincrement())
  subscription_tier SubscriptionTier
  currentStatus     CurrentStatus
  validTill         DateTime
  userId            Int              @unique
  user              User             @relation(fields: [userId], references: [id])
}

model AuthAccount {
  id         Int          @id @default(autoincrement())
  provider   AuthProvider
  providerId String       @unique
  userId     Int
  user       User         @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
  @@index([userId])
}

enum IssuePriority {
  Unseen
  Critical
  High
  Low
  Closed
}

model Issue {
  id                      Int           @id @default(autoincrement())
  issueName               String
  issueDesc               String
  issuePriority           IssuePriority
  issueDateAndTime        DateTime      @default(now())
  issueResolveDateAndTime DateTime?
  filePath                String?
  userId                  Int
  user                    User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, issuePriority])
}

model Incident {
  id                      Int       @id @default(autoincrement())
  projectName             String    @default("Untitled Project")
  incidentName            String
  incidentDesc            String
  incidentSeen            Boolean   @default(false)
  incidentDateAndTime     DateTime  @default(now())
  incidentSeenDateAndTime DateTime?
  filePath                String?
  userId                  Int
  user                    User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, incidentSeen])
}

model ContactDetails {
  id              Int      @id @default(autoincrement())
  telegramChatIds String[]
  discordChatIds  String[]
  projectId       Int      @unique

  project Project @relation(fields: [projectId], references: [id])
}

enum OrderStatus {
  Pending
  Successful
  Failed
}

model Orders {
  id                Int         @id @default(autoincrement())
  razorPayOrderId   String      @unique
  razorPayPaymentId String?
  amount            Int
  status            OrderStatus
  note              String?
  userId            Int
  user              User        @relation(fields: [userId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @default(now()) @updatedAt

  @@index([userId])
}
